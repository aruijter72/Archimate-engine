<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:archimate="http://www.archimatetool.com/archimate" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="ArchiMate Model" id="id-a1c60de0a2a2" version="4.0">
  <folder name="Strategy" id="id-39d891d5fe18" type="strategy"/>
  <folder name="Business" id="id-d0bd76c73583" type="business">
    <element xsi:type="archimate:BusinessActor" name="Municipality" id="b001">
      <documentation>Contracting authority issuing the ESB tender under EU Directive 2014/24/EU</documentation>
      <property key="Tags" value="contracting-authority"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessActor" name="ESB Vendor" id="b002">
      <documentation>Supplier submitting a tender offer for the ESB solution</documentation>
      <property key="Tags" value="vendor, tenderer"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessCollaboration" name="Evaluation Committee" id="b003">
      <documentation>Multi-disciplinary team assessing offers on technical and financial criteria</documentation>
      <property key="Tags" value="procurement, evaluation"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Contracting Officer" id="b004">
      <documentation>Manages the full procurement process and ensures legal compliance</documentation>
      <property key="Tags" value="procurement"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessRole" name="IT Architect" id="b005">
      <documentation>Defines technical requirements and assesses vendor solutions</documentation>
      <property key="Tags" value="technical"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Legal Advisor" id="b006">
      <documentation>Ensures tender process complies with EU and national procurement law</documentation>
      <property key="Tags" value="legal, compliance"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Needs Assessment" id="b007">
      <documentation>Identify functional and non-functional ESB requirements across the municipality</documentation>
      <property key="Tags" value="phase-1"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Market Consultation" id="b008">
      <documentation>Prior Information Notice (PIN) and Request for Information to map the ESB market</documentation>
      <property key="Tags" value="phase-2"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Tender Preparation" id="b009">
      <documentation>Draft technical specifications, award criteria, and tender documents per EU rules</documentation>
      <property key="Tags" value="phase-3"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Tender Publication" id="b010">
      <documentation>Publish call for tender on TED (Tenders Electronic Daily) and national platform</documentation>
      <property key="Tags" value="phase-4"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Tender Reception" id="b011">
      <documentation>Receive, register and safeguard vendor offers within the submission deadline</documentation>
      <property key="Tags" value="phase-5"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Tender Evaluation" id="b012">
      <documentation>Assess offers against technical (BPQR) and financial criteria; MEAT principle</documentation>
      <property key="Tags" value="phase-6"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Contract Award" id="b013">
      <documentation>Notify winning vendor, publish award notice on TED, observe standstill period</documentation>
      <property key="Tags" value="phase-7"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="ESB Implementation" id="b014">
      <documentation>Deploy, configure and integrate the ESB solution within municipal IT landscape</documentation>
      <property key="Tags" value="phase-8"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Acceptance Testing" id="b015">
      <documentation>Formal acceptance test and go-live sign-off by municipal IT and business owners</documentation>
      <property key="Tags" value="phase-9"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessService" name="Procurement Service" id="b016">
      <documentation>End-to-end procurement management service provided to the municipality</documentation>
      <property key="Tags" value="service"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Technical Spec" id="b017">
      <documentation>Document defining ESB functional requirements, integration scenarios and NFRs</documentation>
      <property key="Tags" value="document"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Tender Offer" id="b018">
      <documentation>Vendor response including technical proposal, pricing and references</documentation>
      <property key="Tags" value="document"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Award Notice" id="b019">
      <documentation>Official contract award notice published on TED after standstill period</documentation>
      <property key="Tags" value="document"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:Contract" name="ESB Contract" id="b020">
      <documentation>Signed contract covering licence, implementation, SLA and maintenance</documentation>
      <property key="Tags" value="document, legal"/>
      <property key="Status" value="Active"/>
    </element>
  </folder>
  <folder name="Application" id="id-fbbffa82dd73" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="ESB Platform" id="a001">
      <documentation>Core enterprise service bus: message routing, transformation and orchestration</documentation>
      <property key="Tags" value="core, esb"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="API Gateway" id="a002">
      <documentation>Manages API lifecycle, security, throttling and versioning for all services</documentation>
      <property key="Tags" value="api, security"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Message Broker" id="a003">
      <documentation>Asynchronous messaging backbone (e.g. ActiveMQ, RabbitMQ)</documentation>
      <property key="Tags" value="messaging"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Service Registry" id="a004">
      <documentation>Catalogue of available services, endpoints and contracts</documentation>
      <property key="Tags" value="governance"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Monitoring Console" id="a005">
      <documentation>Real-time operational monitoring, alerting and SLA dashboards</documentation>
      <property key="Tags" value="operations"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Identity &amp; Access Mgmt" id="a006">
      <documentation>Central IAM for service authentication and authorisation (OAuth2/SAML)</documentation>
      <property key="Tags" value="security"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Message Routing Service" id="a007">
      <documentation>Routes messages between source and target systems based on content and rules</documentation>
      <property key="Tags" value="core, routing"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Data Transformation Svc" id="a008">
      <documentation>Transforms data formats (XML↔JSON, canonical model mapping)</documentation>
      <property key="Tags" value="core, transformation"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Protocol Mediation Svc" id="a009">
      <documentation>Bridges REST, SOAP, JMS, SFTP and legacy protocols</documentation>
      <property key="Tags" value="core, mediation"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Service Orchestration" id="a010">
      <documentation>Coordinates multi-step integration flows and business processes</documentation>
      <property key="Tags" value="core, orchestration"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:DataObject" name="Integration Schema" id="a011">
      <documentation>Canonical data model and XSD/JSON schemas for all integrated systems</documentation>
      <property key="Tags" value="data, governance"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:DataObject" name="API Specification" id="a012">
      <documentation>OpenAPI/WSDL definitions for all exposed and consumed services</documentation>
      <property key="Tags" value="data, api"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:DataObject" name="SLA Definition" id="a013">
      <documentation>Service level parameters: availability, throughput, latency, support tiers</documentation>
      <property key="Tags" value="data, governance"/>
      <property key="Status" value="Active"/>
    </element>
  </folder>
  <folder name="Technology &amp; Physical" id="id-63687c0697c5" type="technology">
    <element xsi:type="archimate:Node" name="Integration Server" id="t001">
      <documentation>Primary server (on-prem or cloud VM) hosting ESB runtime</documentation>
      <property key="Tags" value="infrastructure"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:Node" name="Message Queue Server" id="t002">
      <documentation>Dedicated server for async message broker and persistent queues</documentation>
      <property key="Tags" value="infrastructure"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:Node" name="API Gateway Server" id="t003">
      <documentation>Server or load-balanced cluster hosting the API Gateway</documentation>
      <property key="Tags" value="infrastructure"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="ESB Software Package" id="t004">
      <documentation>Licensed ESB middleware (e.g. MuleSoft, WSO2, IBM App Connect)</documentation>
      <property key="Tags" value="software, licence"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Container Platform" id="t005">
      <documentation>Docker/Kubernetes for containerised ESB deployment and scaling</documentation>
      <property key="Tags" value="software, infra"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Operating System" id="t006">
      <documentation>RHEL or Ubuntu LTS; hardened per municipal security baseline</documentation>
      <property key="Tags" value="software"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="Municipal Network" id="t007">
      <documentation>Internal municipal LAN/WAN connecting all back-office systems</documentation>
      <property key="Tags" value="network"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="DMZ" id="t008">
      <documentation>Demilitarised zone for controlled external partner access to ESB APIs</documentation>
      <property key="Tags" value="network, security"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:Artifact" name="Deployment Package" id="t009">
      <documentation>ESB installation scripts, Helm charts and configuration artefacts</documentation>
      <property key="Tags" value="devops"/>
      <property key="Status" value="Active"/>
    </element>
  </folder>
